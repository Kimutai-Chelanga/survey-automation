#     echo 'VNC available on port 6080 (password: secret)' && \
#     tail -f /tmp/chrome_shared.log /tmp/x11vnc.log\
# "]

# Expose ports
# 6080: VNC for visual debugging
# 9222-9250: Chrome remote debugging ports (range for multiple instances)
EXPOSE 6080 9222-9250

# Health check
HEALTHCHECK --interval=30s --timeout=10s --retries=3 --start-period=10s \
    CMD /usr/local/bin/healthcheck.sh