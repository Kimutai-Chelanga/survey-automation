# ============================================================================
# ENVIRONMENT TEMPLATE - Copy to .env.production and fill in actual values
# ============================================================================

# GitHub
GITHUB_REPOSITORY=your-username/your-repo

# Server
SERVER_HOST=your.server.ip
ENVIRONMENT=production
DEBUG=false

# App Authentication
APP_USERNAME=admin
APP_PASSWORD_HASH=generate_with_bcrypt
SESSION_TIMEOUT=480

# PostgreSQL
POSTGRES_USER=automation_prod
POSTGRES_PASSWORD=generate_strong_password
POSTGRES_DB=messages

# MongoDB
MONGO_ROOT_USER=admin
MONGO_ROOT_PASSWORD=generate_strong_password
MONGO_DB=messages_db

# Airflow
AIRFLOW_UID=50000
AIRFLOW_GID=0
AIRFLOW_FERNET_KEY=generate_with_fernet
AIRFLOW_WEBSERVER_SECRET_KEY=generate_strong_password
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=generate_strong_password

# VNC
VNC_PASSWORD=generate_strong_password

# API Keys
GEMINI_API_KEY=your_key
OPENAI_API_KEY=your_key
HYPERBROWSER_API_KEY=your_key

# Timezone & Schedule
DAG_TIMEZONE=Africa/Nairobi
DAG_SCHEDULE=0 16 * * 0
DAG_START_DATE=2025-07-01

# Backup
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=7
